{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "opencode-plugin-mercado",
  "version": "0.1.0",
  "description": "Plugin opencode para dados de mercado cripto: cotação Binance, orderbook L2, spread/half-spread em bps.",
  "type": "module",
  "license": "MIT",
  "keywords": [
    "opencode",
    "opencode-plugin",
    "trading",
    "binance",
    "orderbook",
    "hft"
  ],
  "exports": {
    "./server": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "opencode": ">=0.1.0"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsc",
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "peerDependencies": {
    "@opencode-ai/plugin": ">=1.17.0"
  }
}
